# LLM Provider — set one or both
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Which provider to use: "openai" or "anthropic"
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o

# Langfuse observability
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=http://localhost:3000

# Search APIs (optional - DuckDuckGo is used as fallback)
EXA_API_KEY=
TAVILY_API_KEY=

# MCP server
MCP_SERVER_URL=http://localhost:8001

# Token budgets per agent (defaults shown)
SUPERVISOR_TOKEN_BUDGET=4000
RESEARCHER_TOKEN_BUDGET=8000
ANALYST_TOKEN_BUDGET=8000
WRITER_TOKEN_BUDGET=10000
REVIEWER_TOKEN_BUDGET=6000

# Retry config
MAX_RETRIES=3
RETRY_BASE_DELAY=1.0

# Cost per 1M tokens (GPT-4o defaults)
INPUT_COST_PER_M=2.50
OUTPUT_COST_PER_M=10.00
